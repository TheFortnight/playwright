{
  "$schema": "https://opencode.ai/config.json",
  "agents": {
    "pm": {
      "model": "gpt-5.4"
    },
    "analysis": {
      "model": "gpt-5.4-mini"
    },
    "executor": {
      "model": "gpt-5.4-mini"
    },
    "reviewer": {
      "model": "gpt-5.4"
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": "ask"
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ]
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "filesystem": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/Expero/playwright",
        "C:/Expero/autotest",
        "C:/Expero/opencode"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "allure": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "uv",
        "run",
        "--with",
        "mcp[cli]",
        "mcp",
        "run",
        "C:/Expero/opencode/mcp-allure/mcp-allure-server.py"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "coverage/**",
      "playwright-report/**",
      "test-results/**",
      "allure-results/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "instructions": [
    "C:\\Expero\\opencode\\shared\\core-prompt-playwright.md",
    "C:\\Expero\\opencode\\shared\\shared-memory.md",
    "C:\\Expero\\opencode\\shared\\save-session-template.md",
    "C:\\Expero\\opencode\\playwright\\project-rules.md",
    "C:\\Expero\\opencode\\playwright\\porting-rules.md",
    "C:\\Expero\\opencode\\playwright\\prompt-templates.md",
    "C:\\Expero\\opencode\\playwright\\review-loop.md",
    "C:\\Expero\\opencode\\playwright\\migration-memory.md"
  ]
}